# ---- Server ----
PORT=8080
# Comma-separated list of allowed frontend origins (CORS).
# Example: https://membes.in,https://www.membes.in,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ---- Database (optional) ----
# Used only to log contact submissions. If omitted, emails still send.
DATABASE_URL=mongodb+srv://<user>:<pass>@<cluster>/<db>

# ---- Email (SMTP) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password
# "From" header shown to recipients (optional).
MAIL_FROM="Membes" <you@yourdomain.com>
# Inbox where contact-form enquiries are delivered.
# Defaults to SMTP_USER if not set.
CONTACT_NOTIFY_EMAIL=you@yourdomain.com
